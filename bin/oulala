#!/bin/bash
# Oulala CLI — your personal AI assistant
set -e

OULALA_DIR="${OULALA_DIR:-$HOME/.oulala}"
CMD="$1"
shift 2>/dev/null || true

case "$CMD" in
  start)
    cd "$OULALA_DIR"
    if command -v caffeinate &> /dev/null; then
      caffeinate -s claude --dangerously-skip-permissions --name "Oulala" --remote-control "$@"
    else
      claude --dangerously-skip-permissions --name "Oulala" --remote-control "$@"
    fi
    ;;

  update)
    exec "$OULALA_DIR/bin/update.sh"
    ;;

  sync)
    exec "$OULALA_DIR/bin/sync.sh" "$@"
    ;;

  help|-h|--help|"")
    echo "Oulala — your personal AI assistant"
    echo ""
    echo "Usage: oulala <command>"
    echo ""
    echo "Commands:"
    echo "  start    Start Oulala with remote control"
    echo "  update   Pull latest updates and merge"
    echo "  sync     Sync memories across devices"
    echo "             setup  — set up sync (first time)"
    echo "             pull   — pull latest memories"
    echo "             push   — push local memories"
    echo "  help     Show this help"
    echo ""
    echo "Edit ~/.oulala/brain/SOUL.md to customize your AI's personality."
    ;;

  *)
    echo "Unknown command: $CMD"
    echo "Run 'oulala help' for usage."
    exit 1
    ;;
esac
