{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Time: $(date '+%Y-%m-%d %I:%M %p %Z')]\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.oulala/bin/sync-push.sh 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}
